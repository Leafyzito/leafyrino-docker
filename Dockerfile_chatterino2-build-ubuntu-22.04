# cmake
FROM ubuntu:22.04 AS build-cmake

ARG CMAKE_VERSION=4.3.2
ARG CMAKE_SHA256SUM=b0231eb39b3c3cabdc568c619df78208a7bd95ea10c9b2236d61218bac1b367d

ARG NUM_JOBS=4

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8

RUN <<EOF
set -e

apt-get update

apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    libssl-dev \
    locales \
    locales-all \
    curl

apt-get clean
EOF

# Install CMake
RUN <<EOF
set -e
mkdir /tmp/cmake
cd /tmp/cmake
curl --location --output cmake.tar.gz https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}.tar.gz
echo "${CMAKE_SHA256SUM} cmake.tar.gz" | sha256sum --check --status
tar xzf cmake.tar.gz
cd cmake-${CMAKE_VERSION}
./bootstrap --prefix=/usr/local-cmake
make -j${NUM_JOBS}
make install
rm -rf /tmp/cmake
EOF



# boost
FROM ubuntu:22.04 AS build-boost

ARG BOOST_VERSION=1.84.0
ARG BOOST_SHA256SUM=cc4b893acf645c9d4b698e9a0f08ca8846aa5d6c68275c14c3e7949c24109454

ARG NUM_JOBS=4

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8

# COPY --from=build-cmake /usr/local-cmake /usr/local-cmake

RUN <<EOF
set -e

apt-get update

apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    libssl-dev \
    locales \
    locales-all \
    curl

apt-get clean
EOF

RUN <<EOF
set -e
mkdir /tmp/boost
cd /tmp/boost
BOOST_VERSION_MOD=$(echo $BOOST_VERSION | tr . _)
curl --location --output boost.tar.bz2 https://archives.boost.io/release/${BOOST_VERSION}/source/boost_${BOOST_VERSION_MOD}.tar.bz2
echo "$BOOST_SHA256SUM boost.tar.bz2" | sha256sum --check --status
tar --bzip2 -xf boost.tar.bz2
cd boost_${BOOST_VERSION_MOD}
./bootstrap.sh --prefix=/usr/local-boost
./b2 install
rm -rf /tmp/boost
EOF



# Qt
FROM ubuntu:22.04 AS build-qt

ARG QT_TAG=v6.11.1

ARG NUM_JOBS=4

COPY --from=build-cmake /usr/local-cmake /usr/local-cmake

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8
ENV PATH="/usr/local-cmake/bin:${PATH}"

RUN <<EOF
set -e

apt-get update

apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    libssl-dev \
    locales \
    locales-all \
    curl \
    ninja-build \
    git

apt-get install -y --no-install-recommends \
    libgl-dev \
    libz3-dev \
    zlib1g-dev \
    libjpeg-dev \
    libpng-dev \
    libfreetype-dev \
    libpcre2-dev \
    libharfbuzz-dev \
    libx11-xcb-dev \
    libxcb-glx0-dev \
    libxcb-cursor-dev \
    libxcb-icccm4-dev \
    libxcb-image0-dev \
    libxcb-keysyms1-dev \
    libxcb-randr0-dev \
    libxcb-render0-dev \
    libxcb-render-util0-dev \
    libxcb-shape0-dev \
    libxcb-shm0-dev \
    libxcb-sync-dev \
    libxcb-xfixes0-dev \
    libxcb-xkb-dev \
    libxcb-xinput-dev \
    libegl1-mesa-dev \
    libxkbcommon-dev \
    libxkbcommon-x11-dev \
    libfontconfig1-dev \
    pkg-config \
    libxcb1-dev \
    libxcb-util-dev \
    libwebp-dev

# Qt WebEngine build dependencies
# https://doc.qt.io/qt-6/qtwebengine-platform-notes.html
curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
apt-get install -y --no-install-recommends nodejs
apt-get install -y --no-install-recommends \
    python3 \
    python3-html5lib \
    gperf \
    bison \
    flex \
    libnss3-dev \
    libnspr4-dev \
    libdbus-1-dev \
    libasound2-dev \
    libpulse-dev \
    libxcomposite-dev \
    libxdamage-dev \
    libxrandr-dev \
    libxtst-dev \
    libdrm-dev \
    libxshmfence-dev \
    libevent-dev \
    libicu-dev \
    libxml2-dev \
    libxslt1-dev \
    libcap-dev \
    libcups2-dev \
    libminizip-dev \
    libre2-dev \
    libsnappy-dev \
    libopus-dev \
    libvpx-dev \
    libpciaccess-dev \
    libxi-dev \
    libxfixes-dev \
    libgl1-mesa-dev

apt-get clean
EOF

# CLONE QT
RUN <<EOF
set -e

mkdir /tmp/qt
cd /tmp/qt
git clone https://github.com/qt/qt5
cd qt5
git checkout ${QT_TAG}

EOF

# INIT QT REPOSITORY
RUN <<EOF
set -e

cd /tmp/qt/qt5

./init-repository --module-subset=qtbase,qtimageformats,qt5compat,qtsvg,qtdeclarative,qtwebchannel,qtpositioning,qtwebengine

EOF

# CONFIGURE & BUILD QT
RUN <<EOF
set -e

cd /tmp/qt/qt5

./configure \
    -prefix /usr/local-qt \
    -release \
    -xcb \
    -xkbcommon \
    -qpa xcb \
    -opensource \
    -system-zlib \
    -system-libjpeg \
    -system-libpng \
    -system-freetype \
    -system-pcre \
    -system-harfbuzz \
    -system-webp \
    -confirm-license \
    -nomake examples \
    -nomake tests \
    -skip qtwebengine

cmake --build . -j${NUM_JOBS}
cmake --install .
EOF

# Qt WebEngine must be built separately (Chromium); static builds are unsupported.
RUN <<EOF
set -e

mkdir /tmp/qt/build-webengine
cd /tmp/qt/build-webengine

/usr/local-qt/bin/qt-configure-module /tmp/qt/qt5/qtwebengine

cmake --build . -j${NUM_JOBS}
cmake --install .
EOF



# Chatterino2
FROM ubuntu:22.04

COPY --from=build-cmake /usr/local-cmake /usr/local-cmake
COPY --from=build-boost /usr/local-boost /usr/local-boost
COPY --from=build-qt /usr/local-qt /usr/local-qt

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8
ENV QT_QPA_PLATFORM=minimal
ENV PATH="/usr/local-cmake/bin:${PATH}"
ENV Qt6_DIR="/usr/local-qt"
ENV Boost_DIR="/usr/local-boost"

RUN <<EOF
set -e

apt-get update

apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    libssl-dev \
    locales \
    locales-all \
    curl \
    libbenchmark-dev \
    git

apt-get install -y --no-install-recommends \
    libgl-dev \
    libz3-dev \
    zlib1g-dev \
    libjpeg-dev \
    libpng-dev \
    libfreetype-dev \
    libpcre2-dev \
    libwebp-dev \
    libharfbuzz-dev

apt-get install -y --no-install-recommends \
    libsecret-1-dev

apt-get install -y --no-install-recommends \
    libgl-dev \
    libz3-dev \
    zlib1g-dev \
    libjpeg-dev \
    libpng-dev \
    libfreetype-dev \
    libpcre2-dev \
    libharfbuzz-dev \
    libx11-xcb-dev \
    libxcb-glx0-dev \
    libxcb-cursor-dev \
    libxcb-icccm4-dev \
    libxcb-image0-dev \
    libxcb-keysyms1-dev \
    libxcb-randr0-dev \
    libxcb-render0-dev \
    libxcb-render-util0-dev \
    libxcb-shape0-dev \
    libxcb-shm0-dev \
    libxcb-sync-dev \
    libxcb-xfixes0-dev \
    libxcb-xkb-dev \
    libxcb-xinput-dev \
    libegl1-mesa-dev \
    libxkbcommon-dev \
    libxkbcommon-x11-dev \
    libfontconfig1-dev \
    pkg-config \
    libxcb1-dev \
    libxcb-util-dev \
    libwebp-dev

# Use system RapidJSON instead of Chatterino submodule
apt-get install -y --no-install-recommends \
    rapidjson-dev

# For builds with desktop notification support (default)
apt-get install -y --no-install-recommends \
    libnotify4 \
    libnotify-dev

# Necessary for GitHub actions
apt-get install -y --no-install-recommends \
        sudo

# Necessary for AppImage creation
apt-get install -y --no-install-recommends \
        file

# Necessary for deb creation
apt-get install -y --no-install-recommends \
        lsb-release

# Runtime libraries for Qt WebEngine/Chromium
apt-get install -y --no-install-recommends \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxtst6 \
    libdrm2 \
    libxshmfence1 \
    libfontconfig1 \
    libcap2 \
    libcups2 \
    libxml2 \
    libxslt1.1

apt-get clean
EOF
